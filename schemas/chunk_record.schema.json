{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jakemorganlabs.com/schemas/chunk_record.schema.json",
  "title": "ChunkRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "document_id",
    "content_hash",
    "source",
    "page",
    "section",
    "chunk_index",
    "char_start",
    "char_end",
    "text",
    "token_count"
  ],
  "properties": {
    "chunk_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "content_hash": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "page": { "type": ["integer", "null"], "minimum": 1 },
    "section": { "type": ["string", "null"] },
    "chunk_index": { "type": "integer", "minimum": 0 },
    "char_start": { "type": ["integer", "null"], "minimum": 0 },
    "char_end": { "type": ["integer", "null"], "minimum": 0 },
    "text": { "type": "string", "minLength": 1 },
    "token_count": { "type": "integer", "minimum": 1 },
    "embedding": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "minItems": 1536,
      "maxItems": 1536
    },
    "embed_model": { "type": ["string", "null"] },
    "embed_dims": { "type": ["integer", "null"], "minimum": 1 },
    "embedded_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
